{
    "baseURL": "https://rewards.bing.com/dashboard",
    "sessionPath": "sessions",
    "headless": true,
    "runOnZeroPoints": false,
    "clusters": 1,
    "errorDiagnostics": true,
    "workers": {
        "doMobileBrowserPhase": true,
        "doDailySet": true,
        "doSpecialPromotions": true,
        "doMorePromotions": true,
        "doAppPromotions": false,
        "doDesktopSearch": true,
        "doMobileSearch": true,
        "doDailyCheckIn": false,
        "doReadToEarn": false,
        "doDailyStreak": false,
        "doRedeemGoal": false,
        "doDashboardInfo": false,
        "doClaimPoints": false,
        "enforceCoreStreakProtectionGate": true
    },
    "searchOnBingLocalQueries": true,
    "globalTimeout": "30sec",
    "searchSettings": {
        "scrollRandomResults": false,
        "clickRandomResults": false,
        "parallelSearching": true,
        "queryEngines": ["google", "wikipedia", "reddit", "local"],
        "searchResultVisitTime": "3sec",
        "searchDelay": {
            "min": "3sec",
            "max": "6sec"
        },
        "readDelay": {
            "min": "10sec",
            "max": "15sec"
        },
        "stagnantLoopMax": 3,
        "extraStagnantLoopMax": 2,
        "relatedQueryExpansionLimit": 8,
        "pointRefreshInterval": 2
    },
    "debugLogs": false,
    "consoleLogFilter": {
        "enabled": false,
        "mode": "whitelist",
        "levels": ["error", "warn"],
        "keywords": ["starting account"],
        "regexPatterns": []
    },
    "proxy": {
        "queryEngine": true
    },
    "webhook": {
        "discord": {
            "enabled": false,
            "url": ""
        },
        "ntfy": {
            "enabled": false,
            "url": "",
            "topic": "",
            "token": "",
            "title": "Orbit",
            "tags": ["bot", "notify"],
            "priority": 3
        },
        "webhookLogFilter": {
            "enabled": false,
            "mode": "whitelist",
            "levels": ["error"],
            "keywords": ["starting account", "select number", "collected"],
            "regexPatterns": []
        }
    },
    "redeemGoal": {
        "enabled": false,
        "skuUrl": "",
        "skuOptionValue": "",
        "redeemMode": "auto"
    },
    "scheduler": {
        "enabled": false,
        "runOnStartup": true,
        "timezone": "Europe/Paris",
        "startTime": "08:00",
        "randomDelay": {
            "min": "0min",
            "max": "30min"
        }
    },
    "safetyAdvisory": {
        "enabled": true,
        "url": "https://raw.githubusercontent.com/AnujYadav-Dev/Orbit-Beta/main/safety-advisory.json",
        "timeout": "10sec",
        "blockedBehavior": "continue"
    },
    "browser": {
        "channel": "chromium"
    }
}
